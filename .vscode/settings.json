{
  // Editor settings
  "editor.formatOnSave": true,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.rulers": [120],
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  },

  // Files settings
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.encoding": "utf8",
  "files.eol": "\n",
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.build": true,
    "**/DerivedData": true,
    "**/*.xcodeproj": true,
    "**/*.xcworkspace": true,
    "**/.swiftpm": true,
    "**/trotter.app": true
  },

  // Swift specific settings
  "[swift]": {
    "editor.defaultFormatter": "sswg.swift-lang",
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },

  // Search settings
  "search.exclude": {
    "**/.build": true,
    "**/DerivedData": true,
    "**/*.xcodeproj": true,
    "**/*.xcworkspace": true,
    "**/.swiftpm": true,
    "**/trotter.app": true
  },
  "swift.buildPath": "${workspaceFolder}/.build",
  "swift.autoGenerateLaunchConfigurations": true,

  // Terminal settings
  "terminal.integrated.env.osx": {
    "PATH": "/usr/bin:/bin:/usr/sbin:/sbin:/usr/local/bin"
  },

  // File associations
  "files.associations": {
    "*.swift": "swift",
    "Package.swift": "swift"
  },

  // Breadcrumbs
  "breadcrumbs.enabled": true,

  // Problems
  "problems.showCurrentInStatus": true
}
